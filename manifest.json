{
  "manifest_version": 3,
  "name": "Downloads Organizer",
  "version": "1.0.0",
  "description": "Automatically sort downloads into Month Year/Category folders (Scripts, Automations, Creatives, Docs, Reports, Others).",
  "permissions": ["downloads", "storage"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "options.html"
}
